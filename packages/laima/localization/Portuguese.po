#: packages/laima/scripts/zone/content/laima/npcs/cities/c_klaipe.cs
msgid "[Storage Keeper] Rita"
msgstr "[Guardiã do Armazém] Rita"

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_klaipe.cs
msgid "Rita"
msgstr "Rita"

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_klaipe.cs
msgid "Hello! Can I help you store your items?"
msgstr "Olá! Posso ajudar a guardar seus itens?"

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_klaipe.cs
msgid "Personal Storage"
msgstr "Armazém Pessoal"

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_klaipe.cs
msgid "Team Storage"
msgstr "Armazém de Equipe"

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_klaipe.cs
msgid "Save Spawn Location"
msgstr "Salvar Local de Reaparecimento"

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_klaipe.cs
msgid "Cancel"
msgstr "Cancelar"

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_klaipe.cs
msgid "Your location has been saved!"
msgstr "Sua localização foi salva!"

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_klaipe.cs
msgid "[Item Merchant] Mirina"
msgstr "[Comerciante de Itens] Mirina"

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_klaipe.cs
msgid "Mirina"
msgstr "Mirina"

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_klaipe.cs
msgid "Care for some potions or helpful consumables?{nl}Buy at Mirina's shop today!"
msgstr "Precisa de poções ou consumíveis úteis?{nl}Compre na loja da Mirina hoje!"

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_klaipe.cs
msgid "Mirina's shop at your service~"
msgstr "A loja da Mirina ao seu dispor~"

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_klaipe.cs
msgid "[Equipment Merchant] Dunkel"
msgstr "[Comerciante de Equipamentos] Dunkel"

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_klaipe.cs
msgid "Dunkel"
msgstr "Dunkel"

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_klaipe.cs
msgid "Take a look around at your own pace without feeling anxious."
msgstr "Dê uma olhada com calma, sem pressa."

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_klaipe.cs
msgid "Weapons"
msgstr "Armas"

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_klaipe.cs
msgid "Armor"
msgstr "Armaduras"

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_klaipe.cs
msgid "[Accessory Merchant] Ronesa"
msgstr "[Comerciante de Acessórios] Ronesa"

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_klaipe.cs
msgid "Ronesa"
msgstr "Ronesa"

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_klaipe.cs
msgid "While you're here, do you need anything?{nl}I've got some hard-to-find stuff."
msgstr "Já que está aqui, precisa de algo?{nl}Tenho algumas coisas difíceis de encontrar."

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_klaipe.cs
msgid "Welcome.{nl}Only hard-to-find stuff here."
msgstr "Bem-vindo.{nl}Só coisas raras por aqui."

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_klaipe.cs
msgid "[Blacksmith]{nl}Zaras"
msgstr "[Ferreiro]{nl}Zaras"

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_klaipe.cs
msgid "[Companion Trader] Christina"
msgstr "[Comerciante de Companheiros] Christina"

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_klaipe.cs
msgid "Christina"
msgstr "Christina"

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_klaipe.cs
msgid "Adopt Companion"
msgstr "Adotar Companheiro"

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_klaipe.cs
msgid "Buy Pet Food"
msgstr "Comprar Ração"

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_klaipe.cs
msgid "Leave"
msgstr "Sair"

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_klaipe.cs
msgid "Statue of Goddess Ausrine"
msgstr "Estátua da Deusa Ausrine"

