# ============================================================================
# Silver Exchanger - Sandra (exchanger.cs)
# ============================================================================

#: custom/npcs/exchanger.cs
msgid "[Silver Exchanger] Sandra"
msgstr "[Cambista] Sandra"

#: custom/npcs/exchanger.cs
msgid "Hi there! I can help you exchange your silver for Goddess Bills. With those, you'll be able to better commercialize your goods with other people! Paper money is the best!"
msgstr "Olá! Posso ajudá-lo a trocar sua prata por Notas da Deusa. Com elas, você poderá comercializar melhor seus produtos com outras pessoas! Dinheiro em papel é o melhor!"

#: custom/npcs/exchanger.cs
msgid "Exchange Silver"
msgstr "Trocar Prata"

#: custom/npcs/exchanger.cs
msgid "Exchange Bills"
msgstr "Trocar Notas"

#: custom/npcs/exchanger.cs
msgid "Nothing"
msgstr "Nada"

#: custom/npcs/exchanger.cs
msgid "Please come back any time."
msgstr "Por favor, volte quando quiser."

#: custom/npcs/exchanger.cs
msgid "Want some shiny paper money? That's the best decision you will ever make!"
msgstr "Quer umas notas brilhantes? Essa é a melhor decisão que você vai tomar!"

#: custom/npcs/exchanger.cs
msgid "Looks like you have {0} silver. How much do you want to exchange?"
msgstr "Parece que você tem {0} de prata. Quanto deseja trocar?"

#: custom/npcs/exchanger.cs
msgid "Sorry, I can only exchange 1000 silver or more!"
msgstr "Desculpe, só posso trocar 1000 de prata ou mais!"

#: custom/npcs/exchanger.cs
msgid "You don't have that much silver! Check your pockets again."
msgstr "Você não tem tanta prata! Verifique seus bolsos novamente."

#: custom/npcs/exchanger.cs
msgid "Thanks for your business!"
msgstr "Obrigada pelo negócio!"

#: custom/npcs/exchanger.cs
msgid "Eh? You want silver? But paper is the future! No, really! Would I lie to you? ... Well, suit yourself."
msgstr "Hã? Você quer prata? Mas papel é o futuro! Sério! Eu mentiria para você? ... Bom, como quiser."

#: custom/npcs/exchanger.cs
msgid "You have bills worth {0} silver. How much silver do you want?"
msgstr "Você tem notas no valor de {0} de prata. Quanta prata você quer?"

#: custom/npcs/exchanger.cs
msgid "Sorry, I have a 1000 silver minimum."
msgstr "Desculpe, o mínimo é 1000 de prata."

#: custom/npcs/exchanger.cs
msgid "I could only give you {0} silver for your bills. That's all you had!"
msgstr "Só consegui te dar {0} de prata pelas suas notas. Era tudo que você tinha!"

#: custom/npcs/exchanger.cs
msgid "Here's your {0} silver. Thanks for the business!"
msgstr "Aqui está sua prata: {0}. Obrigada pelo negócio!"

# ============================================================================
# Stat/Skill Reset - Seraphina (stat_skill_reset.cs)
# ============================================================================

#: custom/npcs/stat_skill_reset.cs
msgid "[Angel] Seraphina"
msgstr "[Anjo] Seraphina"

#: custom/npcs/stat_skill_reset.cs
msgid "Seraphina"
msgstr "Seraphina"

#: custom/npcs/stat_skill_reset.cs
msgid "Greetings, adventurer. I am Seraphina, an angel of the goddess Laima. I can help you redistribute your stat points or reset your skill points, for a fee that increases with each use."
msgstr "Saudações, aventureiro. Eu sou Seraphina, uma anjo da deusa Laima. Posso ajudá-lo a redistribuir seus pontos de atributo ou resetar seus pontos de habilidade, por uma taxa que aumenta a cada uso."

#: custom/npcs/stat_skill_reset.cs
msgid "Stat Reset ({0} Silver)"
msgstr "Reset de Atributos ({0} Prata)"

#: custom/npcs/stat_skill_reset.cs
msgid "Skill Reset ({0} Silver)"
msgstr "Reset de Habilidades ({0} Prata)"

#: custom/npcs/stat_skill_reset.cs
msgid "No thanks."
msgstr "Não, obrigado."

#: custom/npcs/stat_skill_reset.cs
msgid "May the blessings of the goddess Laima be with you."
msgstr "Que as bênçãos da deusa Laima estejam com você."

#: custom/npcs/stat_skill_reset.cs
msgid "stat"
msgstr "atributo"

#: custom/npcs/stat_skill_reset.cs
msgid "skill"
msgstr "habilidade"

#: custom/npcs/stat_skill_reset.cs
msgid "A {0} reset will cost {1} Silver.\nYou have used this service {2} time(s) before."
msgstr "Um reset de {0} custará {1} Prata.\nVocê já usou este serviço {2} vez(es) antes."

#: custom/npcs/stat_skill_reset.cs
msgid "You have reached the maximum price. Further resets will not increase in cost."
msgstr "Você atingiu o preço máximo. Resets futuros não terão aumento de custo."

#: custom/npcs/stat_skill_reset.cs
msgid "{0}\n\nYou don't have enough Silver. You need {1} Silver."
msgstr "{0}\n\nVocê não tem Prata suficiente. Você precisa de {1} Prata."

#: custom/npcs/stat_skill_reset.cs
msgid "Yes, reset my {0}s"
msgstr "Sim, resetar meus {0}s"

#: custom/npcs/stat_skill_reset.cs
msgid "No, nevermind"
msgstr "Não, deixa pra lá"

#: custom/npcs/stat_skill_reset.cs
msgid "Your {0}s have been reset successfully.\n\nYour next {0} reset will cost {1} Silver."
msgstr "Seus {0}s foram resetados com sucesso.\n\nSeu próximo reset de {0} custará {1} Prata."

#: custom/npcs/stat_skill_reset.cs
msgid "Perhaps another time, then."
msgstr "Talvez em outra hora, então."

