msgstr "Alf"

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_orsha.cs
msgid "Looking for potions or other useful items? You've come to the right place!"
msgstr "Procurando poções ou outros itens úteis? Você veio ao lugar certo!"

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_orsha.cs
msgid "Welcome to Alf's shop. What can I get for you today?"
msgstr "Bem-vindo à loja do Alf. O que posso pegar para você hoje?"

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_orsha.cs
msgid "[Accessory Merchant] Jurus"
msgstr "[Comerciante de Acessórios] Jurus"

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_orsha.cs
