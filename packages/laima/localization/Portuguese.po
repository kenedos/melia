msgstr "Aisah"

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_orsha.cs
msgid "Welcome to Orsha's storage. How may I assist you?"
msgstr "Bem-vindo ao armazém de Orsha. Como posso ajudá-lo?"

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_orsha.cs
msgid "[Blacksmith]{nl}Ilanai"
msgstr "[Ferreiro]{nl}Ilanai"

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_orsha.cs
