msgstr "[Comerciante de Acessórios] Joana"

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_fedimian.cs
msgid "Joana"
msgstr "Joana"

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_fedimian.cs
msgid "Accessories~! Everyone loves good looking jewelry!"
msgstr "Acessórios~! Todo mundo ama joias bonitas!"

