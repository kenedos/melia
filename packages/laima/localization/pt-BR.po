msgstr "Mirina"

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_klaipe.cs
msgid "Care for some potions or helpful consumables?{nl}Buy at Mirina's shop today!"
msgstr "Precisa de poções ou consumíveis úteis?{nl}Compre na loja da Mirina hoje!"

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_klaipe.cs
msgid "Mirina's shop at your service~"
msgstr "A loja da Mirina ao seu dispor~"

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_klaipe.cs
msgid "[Equipment Merchant] Dunkel"
msgstr "[Comerciante de Equipamentos] Dunkel"

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_klaipe.cs
msgid "Dunkel"
msgstr "Dunkel"

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_klaipe.cs
msgid "Take a look around at your own pace without feeling anxious."
msgstr "Dê uma olhada com calma, sem pressa."

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_klaipe.cs
msgid "Weapons"
msgstr "Armas"

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_klaipe.cs
