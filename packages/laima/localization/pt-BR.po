msgid "Welcome! What kind of equipment are you looking for?"
msgstr "Bem-vindo! Que tipo de equipamento você procura?"

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_orsha.cs
msgid "[Item Merchant] Alf"
msgstr "[Comerciante de Itens] Alf"

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_orsha.cs
