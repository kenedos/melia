msgstr "Armaduras"

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_klaipe.cs
msgid "[Accessory Merchant] Ronesa"
msgstr "[Comerciante de Acessórios] Ronesa"

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_klaipe.cs
msgid "Ronesa"
msgstr "Ronesa"

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_klaipe.cs
msgid "While you're here, do you need anything?{nl}I've got some hard-to-find stuff."
msgstr "Já que está aqui, precisa de algo?{nl}Tenho algumas coisas difíceis de encontrar."

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_klaipe.cs
msgid "Welcome.{nl}Only hard-to-find stuff here."
msgstr "Bem-vindo.{nl}Só coisas raras por aqui."

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_klaipe.cs
msgid "[Blacksmith]{nl}Zaras"
msgstr "[Ferreiro]{nl}Zaras"

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_klaipe.cs
