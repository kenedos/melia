#: packages/laima/scripts/zone/content/laima/npcs/cities/c_orsha.cs
msgid "[Equipment Merchant] Jura"
msgstr "[Comerciante de Equipamentos] Jura"

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_orsha.cs
msgid "Jura"
msgstr "Jura"

