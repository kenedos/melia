#: packages/laima/scripts/zone/content/laima/npcs/cities/c_fedimian.cs
msgid "Statue of Goddess Vakarine"
msgstr "Estátua da Deusa Vakarine"

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_fedimian.cs
msgid "[Item Merchant] Muras"
msgstr "[Comerciante de Itens] Muras"

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_fedimian.cs
msgid "Muras"
msgstr "Muras"

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_fedimian.cs
msgid "H-Hello there! C-Can I help you with some good consumables?"
msgstr "O-Olá! P-Posso te ajudar com alguns bons consumíveis?"

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_fedimian.cs
msgid "O-Oh, hi. W-Welcome to my humble shop."
msgstr "A-Ah, oi. B-Bem-vindo à minha humilde loja."

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_fedimian.cs
msgid "[Storage Keeper] Zadan"
msgstr "[Guardião do Armazém] Zadan"

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_fedimian.cs
msgid "Zadan"
msgstr "Zadan"

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_fedimian.cs
msgid "Looking for a place to store your items safely? I'm just the guy."
msgstr "Procurando um lugar seguro para guardar seus itens? Eu sou a pessoa certa."

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_fedimian.cs
msgid "[Equipment Merchant] Yorgis"
msgstr "[Comerciante de Equipamentos] Yorgis"

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_fedimian.cs
msgid "Welcome! Only the best quality equipments around here!"
msgstr "Bem-vindo! Só equipamentos da melhor qualidade por aqui!"

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_fedimian.cs
msgid "[Blacksmith]{nl}Anna"
msgstr "[Ferreira]{nl}Anna"

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_fedimian.cs
msgid "[Accessory Merchant] Joana"
msgstr "[Comerciante de Acessórios] Joana"

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_fedimian.cs
msgid "Joana"
msgstr "Joana"

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_fedimian.cs
msgid "Accessories~! Everyone loves good looking jewelry!"
msgstr "Acessórios~! Todo mundo ama joias bonitas!"

