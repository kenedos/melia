msgstr "[Comerciante de Companheiros] Christina"

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_klaipe.cs
msgid "Christina"
msgstr "Christina"

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_klaipe.cs
msgid "Adopt Companion"
msgstr "Adotar Companheiro"

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_klaipe.cs
msgid "Buy Pet Food"
msgstr "Comprar Ração"

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_klaipe.cs
msgid "Leave"
msgstr "Sair"

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_klaipe.cs
msgid "Statue of Goddess Ausrine"
msgstr "Estátua da Deusa Ausrine"

