#: packages/laima/scripts/zone/content/laima/npcs/cities/c_orsha.cs
msgid "Welcome to my accessory shop. I have some rare and unique items you might be interested in."
msgstr "Bem-vindo à minha loja de acessórios. Tenho alguns itens raros e únicos que podem te interessar."

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_orsha.cs
msgid "Greetings! Looking for something to enhance your style and power?"
msgstr "Saudações! Procurando algo para melhorar seu estilo e poder?"

#: packages/laima/scripts/zone/content/laima/npcs/cities/c_orsha.cs
